# CAIW Backend Configuration
# Copy this file to .env and modify as needed

# Set to True to bypass all AI calls (returns pre-baked data)
MOCK_AI=True

# LLM Provider: ollama | nvidia | openai | lmstudio
LLM_PROVIDER=nvidia
LLM_ENDPOINT=http://localhost:11434
LLM_MODEL=mistral

# NVIDIA API (optional, set via Settings UI)
# NVIDIA_API_KEY=nvapi-...
NVIDIA_ENDPOINT=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=moonshotai/kimi-k2.6

# Image Provider: local_sd | replicate
IMAGE_PROVIDER=local_sd
IMAGE_ENDPOINT=http://localhost:7860
